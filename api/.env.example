OAUTH__FRONTEND_SUCCESS_URL=http://localhost:3000/oauth/callback
OAUTH__FRONTEND_ERROR_URL=http://localhost:3000/oauth/error

# Frontend URL
API__FRONTEND_URL=http://localhost:3000
